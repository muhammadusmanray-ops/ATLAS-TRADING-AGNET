# ATLAS Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.

# ── AI / LLM ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=           # https://console.groq.com — free tier available
GEMINI_API_KEY=         # https://aistudio.google.com — optional, used by @google/genai

# ── News & Search ─────────────────────────────────────────────────────────────
TAVILY_API_KEY=         # https://tavily.com — Nova sentiment agent needs this

# ── Exchange ──────────────────────────────────────────────────────────────────
KRAKEN_API_KEY=         # Kraken REST API key (paper trading works without this)
KRAKEN_PRIVATE_KEY=     # Kraken REST API secret

# ── Blockchain / ERC-8004 ─────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=     # EVM wallet private key — used for EIP-712 trade signing (Base Sepolia)

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=           # PostgreSQL connection string — e.g. from Neon: postgresql://user:pass@host/db?sslmode=require

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development    # Set to "production" for Vercel / deployed environments
CORS_ORIGIN=http://localhost:3000  # Allowed frontend origin
